{
  "expo": {
    "name": "Gbolo Fitness and Nutrition",
    "slug": "gbolo-fitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gbolo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fit.gbolo.app",
      "buildNumber": "1",
      "privacyUrl": "https://gbolo.fit/privacy",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Gbolo uses your location to track your running routes, distance, and pace.",
        "NSCameraUsageDescription": "Gbolo uses the camera to photograph food for nutritional analysis.",
        "NSPhotoLibraryUsageDescription": "Gbolo accesses your photo library to select food photos for nutritional analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B3A27",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "fit.gbolo.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B3A27"
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Gbolo uses your location to track your running routes, distance, and pace."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Gbolo uses the camera to photograph food for nutritional analysis."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
